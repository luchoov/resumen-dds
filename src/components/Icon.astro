---
/**
 * Set de iconos de línea propios (sin emojis).
 * Trazo monocromo que hereda `currentColor`. Estilo "manual técnico".
 */
interface Props {
  name: string;
  size?: number;
  stroke?: number;
  class?: string;
}
const { name, size = 24, stroke = 1.6, class: klass } = Astro.props;

const icons: Record<string, string> = {
  // --- Temáticos (unidades / bloques) ---
  server: '<rect x="3" y="4" width="18" height="7" rx="1.5"/><rect x="3" y="13" width="18" height="7" rx="1.5"/><line x1="7" y1="7.5" x2="7.01" y2="7.5"/><line x1="7" y1="16.5" x2="7.01" y2="16.5"/>',
  route: '<circle cx="6" cy="19" r="2.6"/><circle cx="18" cy="5" r="2.6"/><path d="M8.6 19h7a3.4 3.4 0 0 0 0-6.8h-11a3.4 3.4 0 0 1 0-6.8h6.8"/>',
  layers: '<path d="M12 2.5 2.6 7 12 11.5 21.4 7Z"/><path d="m2.6 12.5 9.4 4.5 9.4-4.5"/><path d="m2.6 17 9.4 4.5 9.4-4.5"/>',
  flask: '<path d="M9 2h6"/><path d="M10 2v6.6L5.1 17a2 2 0 0 0 1.8 3h10.2a2 2 0 0 0 1.8-3L14 8.6V2"/><path d="M7.4 14h9.2"/>',
  shield: '<path d="M12 2 4 5v6c0 5.5 4.6 8.6 8 10 3.4-1.4 8-4.5 8-10V5Z"/><path d="m9 12 2 2 4-4"/>',
  lock: '<rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/>',
  atom: '<circle cx="12" cy="12" r="1.4" fill="currentColor" stroke="none"/><ellipse cx="12" cy="12" rx="10" ry="4.3"/><ellipse cx="12" cy="12" rx="10" ry="4.3" transform="rotate(60 12 12)"/><ellipse cx="12" cy="12" rx="10" ry="4.3" transform="rotate(120 12 12)"/>',
  hook: '<circle cx="12" cy="5" r="2.4"/><line x1="12" y1="22" x2="12" y2="7.4"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.6 8.4-2.2 5.2-5.2 2.2 2.2-5.2Z"/>',
  form: '<rect x="4" y="3" width="16" height="18" rx="2"/><line x1="8" y1="8" x2="16" y2="8"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="8" y1="16" x2="13" y2="16"/>',
  plug: '<path d="M12 22v-4.5"/><path d="M9 8.5V2.5"/><path d="M15 8.5V2.5"/><path d="M18 8.5v4a4 4 0 0 1-4 4h-4a4 4 0 0 1-4-4v-4Z"/>',
  pencil: '<path d="M12 20h9"/><path d="M16.5 3.5a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/>',

  // --- Marcadores de callout ---
  info: '<circle cx="12" cy="12" r="9"/><line x1="12" y1="11" x2="12" y2="16.5"/><line x1="12" y1="7.6" x2="12.01" y2="7.6"/>',
  tip: '<path d="M9.2 18h5.6"/><path d="M10 21.5h4"/><path d="M12 2.5a6.8 6.8 0 0 0-4 12.3c.6.5.9 1.2.9 1.9V18h6.2v-1.3c0-.7.3-1.4.9-1.9A6.8 6.8 0 0 0 12 2.5Z"/>',
  warn: '<path d="M10.3 3.4 1.9 18a2 2 0 0 0 1.7 3h16.8a2 2 0 0 0 1.7-3L13.7 3.4a2 2 0 0 0-3.4 0Z"/><line x1="12" y1="9.5" x2="12" y2="13.5"/><line x1="12" y1="17" x2="12.01" y2="17"/>',
  danger: '<circle cx="12" cy="12" r="9"/><line x1="6" y1="6" x2="18" y2="18"/>',
  analogia: '<path d="M3 9h14l-3.2-3.2"/><path d="M21 15H7l3.2 3.2"/>',
  parcial: '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.8"/><circle cx="12" cy="12" r="1" fill="currentColor" stroke="none"/>',

  // --- UI ---
  menu: '<line x1="4" y1="7" x2="20" y2="7"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="17" x2="20" y2="17"/>',
  close: '<line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2.5v2M12 19.5v2M2.5 12h2M19.5 12h2M5.2 5.2 6.6 6.6M17.4 17.4l1.4 1.4M18.8 5.2 17.4 6.6M6.6 17.4 5.2 18.8"/>',
  moon: '<path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"/>',
  arrowRight: '<line x1="4" y1="12" x2="19" y2="12"/><path d="m13 6 6 6-6 6"/>',
  arrowLeft: '<line x1="20" y1="12" x2="5" y2="12"/><path d="m11 6-6 6 6 6"/>',
  book: '<path d="M3 5a2 2 0 0 1 2-2h6v16H5a2 2 0 0 0-2 2Z"/><path d="M21 5a2 2 0 0 0-2-2h-6v16h6a2 2 0 0 1 2 2Z"/>',
  diamond: '<path d="M12 3 21 12 12 21 3 12Z"/>',
  arrowUpRight: '<path d="M7 17 17 7"/><path d="M8 7h9v9"/>',
};

const body = icons[name] ?? icons.info;
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={stroke}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={klass}
  aria-hidden="true"
  set:html={body}
/>
